NODE_ENV=development
PORT=3003
DB_HOST=localhost
DB_PORT=5432
DB_NAME=skillforge
DB_USERNAME=skillforge
DB_PASSWORD=skillforge

# --- LLM Configuration ---
# Provider: anthropic (default), openai, bedrock, azure
LLM_PROVIDER=anthropic

# Model overrides (optional — each provider has sensible defaults)
# LLM_CHAT_MODEL=claude-opus-4-6
# LLM_FAST_MODEL=claude-sonnet-4-5-20250929

# --- Provider credentials (only the one matching LLM_PROVIDER is needed) ---

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# AWS Bedrock — uses default AWS credential chain (no key needed here)
# AWS_REGION=us-east-1

# --- Authentication ---
# Method: local (default), oidc, saml
AUTH_METHOD=local

# OIDC (Okta, Azure AD, Google Workspace, Auth0, Keycloak, etc.)
# OIDC_ISSUER_URL=https://accounts.google.com
# OIDC_CLIENT_ID=...
# OIDC_CLIENT_SECRET=...
# OIDC_REDIRECT_URI=http://localhost:3003/api/auth/sso/callback
# OIDC_SCOPES=openid email profile

# SAML (ADFS, Okta SAML, Shibboleth, etc.)
# SAML_ENTRY_POINT=https://idp.example.com/sso/saml
# SAML_ISSUER=skillforge
# SAML_CALLBACK_URL=http://localhost:3003/api/auth/sso/callback
# SAML_CERT=MIICpDCCAYwCCQ...

# SSO user provisioning
# SSO_AUTO_CREATE_USERS=true
# SSO_DEFAULT_TEAM_ID=1
