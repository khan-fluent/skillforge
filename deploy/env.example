# ============================================================================
# Skillforge — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================================

# --- Required -----------------------------------------------------------

# Docker image URI (provided with your Skillforge license)
SKILLFORGE_IMAGE=ghcr.io/khan-fluent/skillforge:latest

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=

# Database
DB_PASSWORD=change-me-to-a-strong-password
# DB_NAME=skillforge
# DB_USERNAME=skillforge
# DB_PORT=5432

# Encryption key for secrets at rest (Jira tokens, etc.)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# CORS: comma-separated allowed origins
CORS_ALLOWED_ORIGINS=https://skillforge.yourcompany.com

# DB SSL: set to "false" only if using self-signed certs
# DB_SSL_REJECT_UNAUTHORIZED=true

# Port the app listens on
# PORT=3003

# --- AI/LLM Provider (pick one) ----------------------------------------

# Anthropic Claude (default)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# AWS Bedrock (uses IAM credentials from environment)
# LLM_PROVIDER=bedrock
# AWS_REGION=us-east-1

# Azure OpenAI
# LLM_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Model overrides (optional — each provider has sensible defaults)
# LLM_CHAT_MODEL=
# LLM_FAST_MODEL=

# --- Authentication (pick one) ------------------------------------------

AUTH_METHOD=local

# OIDC (Okta, Azure AD, Google Workspace, Auth0, Keycloak)
# AUTH_METHOD=oidc
# OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant}/v2.0
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://skillforge.yourcompany.com/api/auth/sso/callback

# SAML (ADFS, Shibboleth)
# AUTH_METHOD=saml
# SAML_ENTRY_POINT=https://idp.yourcompany.com/sso/saml
# SAML_ISSUER=skillforge
# SAML_CALLBACK_URL=https://skillforge.yourcompany.com/api/auth/sso/callback
# SAML_CERT=MIICpDCCAYwCCQ...

# SSO user provisioning (only when AUTH_METHOD is oidc or saml)
# SSO_AUTO_CREATE_USERS=true
# SSO_DEFAULT_TEAM_ID=1
